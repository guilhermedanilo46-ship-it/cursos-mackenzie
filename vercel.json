{
  "version": 2,
  "builds": [
    {
      "src": "api/gerar.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "mackenzie_banner.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/gerar",
      "dest": "api/gerar.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
